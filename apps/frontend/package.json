{
	"name": "@santan/frontend",
	"private": true,
	"type": "module",
	"license": "MIT",
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "NODE_ENV=production vite build",
		"serve": "vite preview",
		"start": "node .output/server/index.mjs",
		"vitest": "vitest run",
