		"clean": "rm -rf .output dist .turbo",
		"setup:preview-secret": "node scripts/create-preview-secret.js",
		"get:preview-secret": "node scripts/get-preview-secret.js",
		"cleanup:preview-secrets": "node scripts/cleanup-preview-secrets.js",
		"publish:preview-secret": "node scripts/publish-secret.js"
