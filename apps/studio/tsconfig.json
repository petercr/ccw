{
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"target": "ES2017",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"module": "Preserve",
		"moduleResolution": "bundler",
		"moduleDetection": "force",
		"isolatedModules": true,
		"jsx": "preserve",
		"incremental": true,
		"baseUrl": ".",
		"paths": {
			"@santan/shared": ["../../packages/shared/src/index.ts"],
			"@santan/shared/types": ["../../packages/shared/src/types/index.ts"]
		}
	},
	"include": ["**/*.ts", "**/*.tsx"],
	"exclude": ["node_modules"]
}
